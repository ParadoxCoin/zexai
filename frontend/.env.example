# API (production: https://api.zexai.io/api/v1)
VITE_API_URL=http://localhost:8000/api/v1

# WebSocket (production: wss://api.zexai.io/ws)
VITE_WS_URL=ws://localhost:8000/ws

# Supabase (anon key — protect with RLS policies)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Polygon read-only RPC (use Alchemy/Infura URL with API key — set in Vercel env, never commit real keys)
VITE_ALCHEMY_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your-alchemy-key

# Push notifications (optional)
VITE_VAPID_PUBLIC_KEY=
