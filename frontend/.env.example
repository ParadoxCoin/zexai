# API — production MUST use api.zexai.io (not raw railway.app URL; CORS/proxy)
VITE_API_URL=http://localhost:8000/api/v1
# Production example: VITE_API_URL=https://api.zexai.io/api/v1

# WebSocket (production: wss://api.zexai.io/ws)
VITE_WS_URL=ws://localhost:8000/ws

# Supabase (anon key — protect with RLS policies)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# NOTE: VITE_ALCHEMY_RPC_URL has been REMOVED.
# Alchemy key now lives only in Railway env (ALCHEMY_RPC_URL) and is
# proxied server-side via /api/v1/rpc/polygon (JWT-authenticated).
# Frontend uses free public polygon-rpc.com for read-only contract calls.

# Push notifications (optional)
VITE_VAPID_PUBLIC_KEY=
